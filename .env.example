# 复制为 .env.local 后填入实际值

# ─── AI 推理（server-only，OpenAI 兼容协议，任选一家）───
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# 前端模型下拉允许的服务端模型白名单（逗号分隔，可按你的供应商扩展）
# AI_ALLOWED_MODELS=deepseek-chat,deepseek-reasoner,qwen-plus,gpt-4o-mini

# ─── 或用其他 OpenAI 兼容模型（server-only）───
# AI_PROVIDER=mimo
# MIMO_API_KEY=your-api-key
# MIMO_BASE_URL=https://your-provider/v1
# MIMO_MODEL=model-name

# 注意：不要把 AI API Key 写成 NEXT_PUBLIC_*，否则会暴露到浏览器端。

# ─── 站点 ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
